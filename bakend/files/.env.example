# =============================================
# COPIA ESTE ARCHIVO COMO .env (sin el .example)
# =============================================

# --- Supabase ---
# Lo encuentras en: Supabase > Settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- JWT ---
# Inventate una cadena larga y secreta, ej: "mi_clave_super_secreta_2024"
JWT_SECRET=cambia_esto_por_algo_secreto_largo

# --- Claves de acceso ---
# La clave que usaran TODOS los coordinadores para entrar
CLAVE_COORDINADORES=clave_coordinadores_2024

# La clave exclusiva del administrador (tu papa)
CLAVE_ADMIN=clave_admin_super_secreta

# --- Servidor ---
PORT=3001
